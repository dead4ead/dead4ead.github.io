<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.0.4 Chrome/128.0.6613.186 Electron/32.2.5 Safari/537.36" version="26.0.4">
  <diagram name="第 1 页" id="2ncE288A32BM-4AAgENl">
    <mxGraphModel dx="2049" dy="1062" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="IrBn3JA5XKyhmPOs2gYu-1" value="用户" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="55" y="240" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-1" value="&lt;span style=&quot;font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-size-adjust: none; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-stretch: normal; font-family: ui-sans-serif, system-ui, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;, &amp;quot;Noto Color Emoji&amp;quot;; font-weight: 700; line-height: 24px; flex: 0 1 auto; flex-direction: row; justify-content: normal; align-items: normal; padding: 0px; margin: 0px; background: none 0% 0% / auto repeat scroll padding-box border-box rgba(0, 0, 0, 0);&quot;&gt;国密合规硬件密码模块&lt;/span&gt;：&lt;div&gt;如 SM2 国密 U 盾、加密机（SKF 接口），用于生成并安全存储签名私钥&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="-110" y="190" width="475" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-7" value="步骤 1：选择合规国密 CA&lt;div&gt;步骤 2：用户生成签名密钥对与 CSR（核心）&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;a.&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;在&lt;b&gt;国密 U 盾 / 加密机&lt;/b&gt;内生成&lt;b&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;SM2 签名密钥对&lt;/font&gt;&lt;/b&gt;（私钥锁在硬件内，不可导出）&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;b.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;导出&lt;b&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;签名公钥&lt;/font&gt;&lt;/b&gt;，并生成&lt;b&gt;证书签名请求（CSR）&lt;/b&gt;，包含：&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;签名公钥&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;主体信息（CN、O、OU、C 等）&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;密钥用途：Digital Signature, Non-Repudiation（标识c0）。&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;c.&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;提交 CSR 给 CA。&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;注意&lt;/b&gt;：&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;用户不生成加密密钥对&lt;/b&gt;，仅提交签名 CSR。&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;步骤 3：提交身份材料并完成验证&lt;br&gt;&lt;/div&gt;&lt;div&gt;步骤 4：等待 CA 签发与国密局监管&lt;br&gt;&lt;/div&gt;&lt;div&gt;步骤 5：用户接收并安全导入双证书与加密私钥&lt;/div&gt;" style="rounded=1;arcSize=9;fillColor=#F7F8F9;align=left;spacingLeft=5;strokeColor=#DEE1E6;html=1;strokeWidth=2;fontColor=#596780;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="-110" y="290" width="450" height="220" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-8" value="国密局" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-9" value="&lt;div&gt;&lt;div&gt;审批 CA 资质，颁发《电子认证服务许可证》&lt;/div&gt;&lt;div&gt;管理国密根 CA 与信任链&lt;/div&gt;&lt;div&gt;监督 CA 密钥生成、证书签发、私钥管理的合规性&lt;/div&gt;&lt;div&gt;备案证书策略与审计日志&lt;/div&gt;&lt;/div&gt;" style="rounded=1;arcSize=9;fillColor=#dae8fc;align=left;spacingLeft=5;strokeColor=#6c8ebf;html=1;strokeWidth=2;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="720" y="180" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-10" value="CA" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="270" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-11" value="顶层监管" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="640" y="205" width="70" height="30" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-12" value="双证书生成与签发" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="650" y="275" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-13" value="&lt;div&gt;阶段 A：处理签名证书&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;1.&amp;nbsp;验证用户提交的&lt;b&gt;签名 CSR&lt;/b&gt;与身份材料&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;2.&amp;nbsp;用&lt;font style=&quot;color: rgb(77, 153, 0);&quot;&gt;&lt;b&gt;CA 签名私钥&lt;/b&gt;&lt;/font&gt;对 CSR 进行 SM2 签名，生成&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;SM2 签名证书&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;证书包含：用户签名公钥、主体信息、有效期、CA 签名、密钥用途（签名）&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;阶段 B：生成加密密钥对与加密证书（CA 端生成）&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;1.&amp;nbsp;CA 在自身 HSM内生成用户专属&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;SM2 加密密钥对（加密公钥 + 加密私钥）&lt;/b&gt;&lt;/font&gt;。&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;2.&amp;nbsp;用&lt;b&gt;&lt;font style=&quot;color: rgb(77, 153, 0);&quot;&gt;CA 签名私钥&lt;/font&gt;&lt;/b&gt;签发&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;SM2 加密证书&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*&amp;nbsp;证书包含：用户加密公钥、主体信息、有效期、CA 签名、密钥用途（加密）。&lt;br&gt;&lt;/div&gt;&lt;div&gt;阶段 C：加密私钥的安全交付（&lt;b&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;数字信封&lt;/font&gt;&lt;/b&gt;）&amp;gt;&amp;gt; 加密私钥必须安全交付，流程：&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;1.&amp;nbsp;CA 生成&lt;b&gt;临时 SM4 对称密钥 K&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;2.&amp;nbsp;用&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;用户签名公钥&lt;/b&gt;&lt;/font&gt;加密 K → 得到K密文&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;3.&amp;nbsp;用 K 加密&lt;b&gt;用户加密私钥&lt;/b&gt; → 得到加密私钥密文&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;4.&amp;nbsp;打包交付：签名证书、加密证书、K密文、加密私钥密文、证书链(根 CA+中间 CA)&lt;/div&gt;" style="rounded=1;arcSize=9;fillColor=#F7F8F9;align=left;spacingLeft=5;strokeColor=#DEE1E6;html=1;strokeWidth=2;fontColor=#596780;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="520" y="320" width="570" height="250" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-14" value="&lt;div&gt;1.&amp;nbsp;将K密文导入硬件 U 盾&lt;/div&gt;&lt;div&gt;2.&amp;nbsp;用 签名私钥（硬件内）解密K密文 → 得到 K&lt;/div&gt;&lt;div&gt;3.&amp;nbsp;用 K 解密加密私钥密文 → 得到&lt;b&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;加密私钥&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;4.&amp;nbsp;将加密私钥导入硬件安全存储，完成双证书部署&lt;/div&gt;" style="rounded=1;arcSize=9;fillColor=#F7F8F9;align=left;spacingLeft=5;strokeColor=#DEE1E6;html=1;strokeWidth=2;fontColor=#596780;fontSize=14;" vertex="1" parent="1">
          <mxGeometry y="520" width="340" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-21" value="SM2Cipher（SM2 加密结果格式）" style="fillColor=none;strokeColor=none;html=1;fontSize=12;fontStyle=0;align=left;fontColor=#596780;fontStyle=1;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="-110" y="618.75" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-22" value="&lt;div&gt;SM2Cipher ::= SEQUENCE {&lt;/div&gt;&lt;div&gt;&amp;nbsp; XCoordinate&amp;nbsp; INTEGER,&amp;nbsp; &amp;nbsp;-- 随机公钥x分量&lt;/div&gt;&lt;div&gt;&amp;nbsp; YCoordinate&amp;nbsp; INTEGER,&amp;nbsp; &amp;nbsp;-- 随机公钥y分量&lt;/div&gt;&lt;div&gt;&amp;nbsp; HASH&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;OCTET STRING SIZE(32),&amp;nbsp; -- SM3(x||K||y)&lt;/div&gt;&lt;div&gt;&amp;nbsp; CipherText&amp;nbsp; &amp;nbsp;OCTET STRING&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; -- 加密后的K密文&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" style="rounded=1;arcSize=9;align=left;spacingLeft=5;strokeColor=#4C9AFF;html=1;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="-110" y="638.75" width="330" height="91.25" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-23" value="SM2EnvelopedKey（密钥对保护数据，即数字信封）" style="fillColor=none;strokeColor=none;html=1;fontSize=11;fontStyle=0;align=left;fontColor=#596780;fontStyle=1;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="-110" y="826.25" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-24" value="SM2EnvelopedKey ::= SEQUENCE {&#xa;  symAlgId     AlgorithmIdentifier,  -- 对称算法标识（SM4-ECB）&#xa;  symKeyCipher SM2Cipher,            -- 被签名公钥加密的SM4密钥K&#xa;  encPubKey    BIT STRING,           -- 用户加密公钥（明文）&#xa;  encPrvCipher BIT STRING            -- 被SM4加密的用户加密私钥&#xa;}" style="rounded=1;arcSize=9;align=left;spacingLeft=5;strokeColor=#4C9AFF;html=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="-110" y="846.25" width="330" height="105" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-25" value="" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="h0ibiiNdMILWjwPAH-NP-7" target="h0ibiiNdMILWjwPAH-NP-13">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="580" y="500" as="sourcePoint" />
            <mxPoint x="630" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-27" value="申请" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=15;" vertex="1" connectable="0" parent="h0ibiiNdMILWjwPAH-NP-25">
          <mxGeometry x="-0.0382" y="1" relative="1" as="geometry">
            <mxPoint x="3" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-26" value="" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="h0ibiiNdMILWjwPAH-NP-13" target="h0ibiiNdMILWjwPAH-NP-14">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="580" y="500" as="sourcePoint" />
            <mxPoint x="630" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-28" value="签发" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=15;" vertex="1" connectable="0" parent="h0ibiiNdMILWjwPAH-NP-26">
          <mxGeometry x="-0.0525" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-30" value="&lt;div&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;SM2私钥签名&lt;/font&gt;：&lt;/font&gt;CA 用签名私钥对 CSR 进行 SM2 签名，生成 SM2 签名证书&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. 预处理：&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;生成CA与CSR的绑定杂凑值&lt;/span&gt;&lt;/div&gt;&lt;div&gt;1.1 预处理1：CA身份杂凑值&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入： &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ID&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串 &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;CA身份标识&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Q&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2PublicKey&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;CA的公钥&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输出：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Z&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;预处理1的输出&lt;/div&gt;&lt;div&gt;1.2 预处理2：CSR预处理杂凑值&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Z&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;预处理1的输出&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;M&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;CSR原文（待签名信息）&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输出：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;H&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;杂凑值&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. SM2&lt;b&gt;&lt;font style=&quot;color: rgb(77, 153, 0);&quot;&gt;签名&lt;/font&gt;&lt;/b&gt;计算&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;d&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2PrivateKey&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;签名者（CA）的私钥&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;H&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;预处理2的结果&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输出：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;sign&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2Signature&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;签名值&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;SM2公钥验&lt;span style=&quot;background-color: transparent;&quot;&gt;签&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;：&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;用 CA 公钥验证签名证书合法性&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;H&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;预处理2的结果（CA和CSR杂凑）&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;sign&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2Signature&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;签名值&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Q&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;PublicKey&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;签名者（CA）的公钥&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输出：为真表示验证通过，为假表示验证不通过&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;strokeWidth=1;strokeColor=default;dashed=1;dashPattern=8 8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="240" y="638.75" width="450" height="331.25" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-33" value="&lt;div&gt;&lt;b&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;SM2公钥加密：&lt;/font&gt;&lt;/b&gt;使用用户签名公钥加密K，得到K的密文&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Q&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2PublicKey&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2（用户）公钥&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;m&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;待加密的明文数据&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输出：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;c&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2Cipher&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;密文&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(255, 51, 51);&quot;&gt;&lt;b&gt;SM2私钥解密：&lt;/b&gt;&lt;/font&gt;使用用户签名私钥解密K的密文（SM2Cipher）&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;d&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2PrivateKey&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2（用户）私钥&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;c&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;SM2Cipher&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;密文&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输出：&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;m&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;字节串&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;与密文对应的明文&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;strokeColor=default;dashed=1;dashPattern=8 8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="700" y="638.75" width="390" height="171.25" as="geometry" />
        </mxCell>
        <mxCell id="h0ibiiNdMILWjwPAH-NP-35" value="SM2Signature（SM2 签名结果格式）" style="fillColor=none;strokeColor=none;html=1;fontSize=11;fontStyle=0;align=left;fontColor=#596780;fontStyle=1;fontSize=11" vertex="1" parent="1">
