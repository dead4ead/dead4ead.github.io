        <mxCell id="h0ibiiNdMILWjwPAH-NP-36" value="&lt;div&gt;SM2Signature ::= SEQUENCE {&lt;/div&gt;&lt;div&gt;&amp;nbsp; R&amp;nbsp; INTEGER,&amp;nbsp; &amp;nbsp;-- 签名值的第一部分&lt;/div&gt;&lt;div&gt;&amp;nbsp; S&amp;nbsp; INTEGER,&amp;nbsp; &amp;nbsp;-- 签名值的第二部分&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;}&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=1;arcSize=9;align=left;spacingLeft=5;strokeColor=#4C9AFF;html=1;strokeWidth=2;fontSize=11;" vertex="1" parent="1">
